# Server
PORT=3000
NODE_ENV=development

# Postgres connection string, e.g. postgres://user:password@host:5432/dbname
DATABASE_URL=

# Set to "false" to disable SSL for local Postgres
DB_SSL=true

# Max connections in the Postgres pool
DB_POOL_MAX=10

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=

# Google Gemini API key, used by /metrics/analyze
GOOGLE_API_KEY=

# Comma-separated list of allowed CORS origins (defaults to localhost + the dashboard)
CORS_ORIGINS=

# Max metrics requests per API key per minute
METRICS_RATE_LIMIT=300
